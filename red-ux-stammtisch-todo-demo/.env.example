# Neon PostgreSQL connection string
# Format: postgresql://user:password@host/dbname?sslmode=require
NUXT_DATABASE_URL=postgresql://user:password@ep-xxxx.eu-central-1.aws.neon.tech/neondb?sslmode=require

# 6-stelliger PIN für den Zugriff auf die App
NUXT_AUTH_PIN=123456

# Beliebiger langer Zufallsstring zum Signieren des Session-Cookies
# Generieren z.B. mit: openssl rand -hex 32
NUXT_SESSION_SECRET=change-me-use-a-long-random-string

# Secret für den Vercel Cron Job (Papierkorb-Cleanup)
# Muss in Vercel als "x-cron-secret" Header konfiguriert werden
NUXT_CRON_SECRET=change-me-cron-secret
